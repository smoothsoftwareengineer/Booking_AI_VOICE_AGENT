RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=
RETELL_LLM_ID=
RETELL_VOICE_ID=11labs-Adrian
RETELL_AGENT_NAME=Service Business Receptionist

# Public URL of this backend (Railway URL after deploy)
WEBHOOK_BASE_URL=https://your-backend.up.railway.app

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# SQLite by default; use PostgreSQL on Railway for persistence
DATABASE_URL=sqlite:///./bookings.db

# Set to true only for local dev without Retell signature
SKIP_WEBHOOK_VERIFY=false
